<Window x:Class="WpfApp17.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp17"
        xmlns:models="clr-namespace:WpfApp17.Models"
        mc:Ignorable="d"
        Title="Учёт результатов экзаменов" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Модуль учёта демонстрационных экзаменов и чемпионатов" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <GroupBox Grid.Row="1" Header="➕ Добавить нового студента" 
                  Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">

                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="ФИО Студента:" FontWeight="SemiBold"/>
                    <TextBox Width="180" Margin="0,5,0,0" 
                             ToolTip="Введите фамилию и инициалы"
                             Text="{Binding NewStudentFIO, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}">
                        <Validation.ErrorTemplate>
                            <ControlTemplate>
                                <StackPanel>
                                    <AdornedElementPlaceholder/>
                                    <TextBlock Text="{Binding [0].ErrorContent}" Foreground="Red" FontSize="10"/>
                                </StackPanel>
                            </ControlTemplate>
                        </Validation.ErrorTemplate>
                    </TextBox>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Специальность:" FontWeight="SemiBold"/>
                    <TextBox Width="180" Margin="0,5,0,0"
                             ToolTip="Например: Программирование"
                             Text="{Binding NewStudentSpecialty, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Тип мероприятия:" FontWeight="SemiBold"/>
                    <ComboBox Width="140" Margin="0,5,0,0"
                              SelectedValue="{Binding NewStudentType}"
                              SelectedValuePath="Content">
                        <ComboBoxItem Content="Демоэкзамен" IsSelected="True"/>
                        <ComboBoxItem Content="Чемпионат"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Год сдачи:" FontWeight="SemiBold"/>
                    <TextBox Width="80" Margin="0,5,0,0"
                             Text="{Binding NewStudentYear, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:####}}"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Балл (%):" FontWeight="SemiBold"/>
                    <TextBox Width="80" Margin="0,5,0,0"
                             ToolTip="От 0 до 100"
                             Text="{Binding NewStudentPercent, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, StringFormat={}{0:0.##}}">
                        <Validation.ErrorTemplate>
                            <ControlTemplate>
                                <StackPanel>
                                    <AdornedElementPlaceholder/>
                                    <TextBlock Text="{Binding [0].ErrorContent}" Foreground="Red" FontSize="10"/>
                                </StackPanel>
                            </ControlTemplate>
                        </Validation.ErrorTemplate>
                    </TextBox>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,0,0">
                    <TextBlock Text="Действия:" FontWeight="SemiBold"/>
                    <Button Content="Добавить" 
                            Command="{Binding AddStudentCommand}"
                            Width="100" Height="28" Margin="0,5,0,0"
                            Background="#4CAF50" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">

            <GroupBox Header="🔍 Фильтр" Padding="10" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Год:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Width="80" Text="{Binding FilterYear, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Применить" 
                            Command="{Binding ApplyFilterCommand}"
                            Margin="10,0,0,0" Width="80"/>
                </StackPanel>
            </GroupBox>

            <Button Content="Импорт" 
                    Command="{Binding ImportCommand}"
                    Width="80" Margin="10,0,5,0"/>
            <Button Content="Отчёт" 
                    Command="{Binding ExportReportCommand}"
                    Width="80" Margin="5,0,5,0"/>
            <Button Content="Удалить" 
                    Command="{Binding DeleteSelectedCommand}"
                    Width="80" Margin="5,0,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="3" x:Name="GridData" 
                  ItemsSource="{Binding Students}"
                  SelectedItem="{Binding SelectedStudent}"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FIO}" Width="180"/>
                <DataGridTextColumn Header="Специальность" Binding="{Binding Specialty}" Width="180"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="120"/>
                <DataGridTextColumn Header="Год" Binding="{Binding Year}" Width="60"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="90"/>
                <DataGridTextColumn Header="Балл %" Binding="{Binding Percent, StringFormat=F1}" Width="70"/>
                <DataGridTextColumn Header="Оценка" Binding="{Binding Grade}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4" Background="#E3F2FD" BorderBrush="#90CAF9" BorderThickness="1" 
                Padding="10" CornerRadius="5" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusMessage}" FontWeight="Medium"/>
                <TextBlock Text=" | " Margin="10,0"/>
                <TextBlock Text="{Binding RecordsCount, StringFormat='Записей: {0}'}" FontWeight="Medium"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>